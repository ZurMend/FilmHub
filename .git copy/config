[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[submodule]
	active = .
[remote "origin"]
	url = https://github.com/ZurMend/FilmHub.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = origin
	merge = refs/heads/main
	vscode-merge-base = origin/main
[lfs]
	repositoryformatversion = 0
[branch "Isaac"]
	vscode-merge-base = origin/main
	remote = origin
	merge = refs/heads/Isaac
[branch "zur"]
	remote = origin
	merge = refs/heads/zur
	vscode-merge-base = origin/zur
[branch "Cris"]
	remote = origin
	merge = refs/heads/Cris
	vscode-merge-base = origin/Cris
